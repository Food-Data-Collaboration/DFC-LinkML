    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass dfc-t:FoafPerson .

dfc-t:Platform a sh:NodeShape ;
    sh:closed true ;
    sh:description "Class from DFC Technical Ontology: #Platform" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass dfc-t:Platform .

dfc-t:RepresentationPivot a sh:NodeShape ;
    sh:closed true ;
    sh:description "Class from DFC Technical Ontology: #RepresentationPivot" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass dfc-t:RepresentationPivot .

dfc-t:RepresentedThing a sh:NodeShape ;
