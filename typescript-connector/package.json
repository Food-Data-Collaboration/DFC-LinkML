{
  "name": "@fooddatacollaboration/linkml-connector",
  "version": "2.0.0",
  "description": "TypeScript connector for the Data Food Consortium (DFC) standard, generated from LinkML schema",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Food-Data-Collaboration/DFC-LinkML.git"
  },
  "bugs": {
    "url": "https://github.com/Food-Data-Collaboration/DFC-LinkML/issues"
  },
  "homepage": "https://github.com/Food-Data-Collaboration/DFC-LinkML#readme",
  "keywords": ["dfc", "food", "data", "ontology", "linkml", "json-ld"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm test && npm run build"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "@types/node": "^20.0.0"
  },
  "license": "MIT"
}
